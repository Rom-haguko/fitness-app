# =================================================================
# ПРИКЛАДНОЕ / ОБЩЕЕ
# =================================================================
.DS_Store
Thumbs.db
*.log
*.tmp
*.temp
.env
.env.local
docker-compose.override.yml

# =================================================================
# JAVA (Spring Boot + Maven)
# =================================================================
**/target/
**/build/
**/*.class
**/*.jar
**/*.war
**/*.ear
# Настройки IDE (IntelliJ IDEA)
**/.idea/
**/*.iml
**/*.iws
# Настройки Eclipse
**/.settings/
**/.project
**/.classpath
**/.factorypath

# =================================================================
# PYTHON (FastAPI / AI)
# =================================================================
**/__pycache__/
**/*.py[cod]
**/*$py.class
# Виртуальные окружения
**/venv/
**/env/
**/.venv/
**/.env/
# Данные и обучение
**/.ipynb_checkpoints/
**/.pytest_cache/
**/.mypy_cache/
**/data_raw/
**/models/*.h5
**/models/*.pkl
**/*.pyc

# =================================================================
# GO (Golang)
# =================================================================
**/bin/
# Исполняемые файлы
**/*.exe
**/*.exe~
**/*.dll
**/*.so
**/*.dylib
# Локальный воркспейс
**/go.work
**/go.work.sum
# Тесты и покрытие
**/*.test
**/c.out

# =================================================================
# DATABASE / DOCKER (PostgreSQL)
# =================================================================
# Игнорируем папку с физическими данными базы (если вы прокинули volume)
**/pgdata/
**/postgres-data/
# Секретные файлы с паролями
**/secrets/

# =================================================================
# IDE / EDITORS
# =================================================================
**/.vscode/
**/*.sublime-project
**/*.sublime-workspace
**/.history/
